# ── LLM (Anthropic — primary) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# ── Embeddings (optional — only needed for RAG material retrieval) ──────────
# If OPENAI_API_KEY is left blank, ChromaDB's built-in local embedding is used.
# OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DSN=postgresql+asyncpg://gauser:gapassword@localhost:5432/gadb

# ── ChromaDB ────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── App ─────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
COURSES_DIR=./courses
